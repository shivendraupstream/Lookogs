generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Severity {
  TRACE
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())
}

model App {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sources     Source[]
  logs        Log[]
  saved_views SavedView[]
}

model Source {
  id          String   @id @default(uuid())
  name        String
  environment String
  apiKeyHash  String   @unique

  appId       String
  app         App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  logs        Log[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("sources")
}

model Log {
  id          String    @id @default(uuid())

  appId       String
  app         App       @relation(fields: [appId], references: [id], onDelete: Cascade)

  sourceId    String
  source      Source    @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  severity    Severity

  message     String

  hostname    String?
  service     String?
  version     String?

  eventTime   DateTime
  ingestTime  DateTime @default(now())

  attributes  Json      @default("{}")

  @@index([sourceId])
  @@index([appId])
  @@index([eventTime])

  @@index([appId, eventTime, id])

  @@map("logs")
}

model SavedView {
  id         String   @id @default(uuid())

  name       String

  filters    Json

  appId      String
  app        App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("saved_views")
}